\name{model_schema}
\alias{model_schema}
\title{Template model schema scaffold}
\usage{model_schema()}
\value{A schema list compatible with \code{fluxCore}.}
\description{
Provides a commented starter schema for building a new model package. The
returned object starts from \code{fluxCore::default_entity_schema()} and adds
example variables/panels to customize.
}
